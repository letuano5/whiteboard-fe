{
  "name": "vdt-whiteboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter whiteboard-fe dev",
    "build": "pnpm --filter whiteboard-fe build",
    "preview": "pnpm --filter whiteboard-fe preview",
    "dev:all": "pnpm --parallel --filter whiteboard-fe --filter whiteboard-be dev",
    "dev:full": "prisma migrate deploy && prisma generate && pnpm dev:all",
    "db:migrate": "prisma migrate deploy && prisma generate",
    "db:generate": "prisma generate",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "benchmark:socket": "tsx benchmarks/socket.ts",
    "benchmark:http": "tsx benchmarks/http.ts",
    "benchmark:render": "tsx benchmarks/render.ts",
    "benchmark:report": "tsx benchmarks/report.ts"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "@vdt/shared": "workspace:*",
    "playwright": "^1.61.1",
    "prisma": "^6.19.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.4"
  }
}
