{
  "name": "vdt-whiteboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter whiteboard-fe dev",
    "build": "pnpm --filter whiteboard-fe build",
    "preview": "pnpm --filter whiteboard-fe preview",
    "dev:all": "pnpm --parallel --filter whiteboard-fe --filter whiteboard-be dev",
    "dev:full": "prisma migrate deploy && pnpm dev:all",
    "db:migrate": "prisma migrate deploy",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
