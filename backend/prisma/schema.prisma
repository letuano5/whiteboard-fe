// Prisma schema for P3A-01: PostgreSQL + Prisma + Autosave
// Matches data model in specs/021-postgresql-prisma-autosave/data-model.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id                            String           @id @default(uuid())
  name                          String           @default("Untitled")
  workspaceId                   String?
  ownerId                       String?
  owner                         AppUser?         @relation("OwnedRooms", fields: [ownerId], references: [id], onDelete: SetNull)
  visibility                    String           @default("private")
  shareRevokedAt                DateTime?
  locked                        Boolean          @default(false)
  archivedAt                    DateTime?
  lastOpenedAt                  DateTime?
  createdBy                     String?
  documentClock                 BigInt           @default(0)
  tombstoneHistoryStartsAtClock BigInt           @default(0)
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt
  members                       RoomMember[]
  invitations                   RoomInvitation[]
  records                       Record[]
  tombstones                    Tombstone[]
}

model RoomMember {
  roomId       String
  userId       String
  role         String
  lastOpenedAt DateTime?
  room         Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user         AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId, lastOpenedAt])
}

model RoomInvitation {
  id          String    @id @default(uuid())
  roomId      String
  email       String
  role        String
  invitedBy   String
  claimedBy   String?
  claimedAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  inviter     AppUser   @relation("SentRoomInvitations", fields: [invitedBy], references: [id], onDelete: Cascade)
  claimedUser AppUser?  @relation("ClaimedRoomInvitations", fields: [claimedBy], references: [id], onDelete: SetNull)

  @@unique([roomId, email])
  @@index([email, revokedAt, claimedAt])
}

model AppUser {
  id                     String           @id @default(uuid())
  provider               String
  providerSubject        String
  email                  String?
  name                   String?
  avatarUrl              String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  ownedRooms             Room[]           @relation("OwnedRooms")
  roomMemberships        RoomMember[]
  sentRoomInvitations    RoomInvitation[] @relation("SentRoomInvitations")
  claimedRoomInvitations RoomInvitation[] @relation("ClaimedRoomInvitations")

  @@unique([provider, providerSubject])
}

model Record {
  roomId      String
  recordId    String
  typeName    String
  state       Json
  recordClock BigInt
  room        Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([roomId, recordId])
  @@index([roomId, recordClock])
}

model Tombstone {
  roomId       String
  recordId     String
  deletedClock BigInt
  room         Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([roomId, recordId])
  @@index([roomId, deletedClock])
}
